# InfraPulse EPC Frontend Configuration
# Authentication Mode: "demo" uses mock login (no Firebase required), "firebase" uses real Firebase Auth
VITE_AUTH_MODE=demo

# Firebase Configuration (only needed if VITE_AUTH_MODE=firebase)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=infrapulse-epc.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=infrapulse-epc
